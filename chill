<script>
// ══════════════════════════════════════════════════════
// FIRMWARE GENERATOR
// ══════════════════════════════════════════════════════
function genFW(board, dhtType, r, g, b, d) {
  const is32 = board === 'esp32';
  return `#include <Arduino.h>
#include <DHT.h>

// ══ Auto-configured by Smart Heat-Guard Web Dashboard ══
#define DHT_PIN    ${d}
#define DHT_TYPE   DHT${dhtType}
#define PIN_RED    ${r}
#define PIN_GREEN  ${g}
#define PIN_BLUE   ${b}

// ══ Heat Index thresholds (°C) ══
#define THRESH_CAUTION  32.0   // Green  → Yellow
#define THRESH_DANGER   41.0   // Yellow → Red

DHT dht(DHT_PIN, DHT_TYPE);
unsigned long lastMs = 0;
int errStreak = 0;

void rgb(bool R, bool G, bool B) {
  digitalWrite(PIN_RED,   R ? HIGH : LOW);
  digitalWrite(PIN_GREEN, G ? HIGH : LOW);
  digitalWrite(PIN_BLUE,  B ? HIGH : LOW);
}

float heatIndex(float T, float H) {
  if (T < 27) return T;
  return -8.784 + 1.611*T + 2.338*H - 0.146*T*H
       - 0.0123*T*T - 0.0164*H*H + 0.00222*T*T*H
       + 0.000725*T*H*H - 0.00000359*T*T*H*H;
}

void setup() {
  Serial.begin(115200);
  dht.begin();
  pinMode(PIN_RED,   OUTPUT);
  pinMode(PIN_GREEN, OUTPUT);
  pinMode(PIN_BLUE,  OUTPUT);

  // Startup RGB blink = board alive
  for (int i = 0; i < 2; i++) {
    rgb(1,0,0); delay(180);
    rgb(0,1,0); delay(180);
    rgb(0,0,1); delay(180);
  }
  rgb(0,0,0);

  // Send board identity (parsed by dashboard)
  Serial.println("BOOT:SmartHeatGuard-${is32 ? 'ESP32' : 'ESP8266'}-DHT${dhtType}");
  Serial.print("PINS:R=${r},G=${g},B=${b},DHT=${d},THRESH_C=");
  Serial.print(THRESH_CAUTION); Serial.print(",THRESH_D=");
  Serial.println(THRESH_DANGER);
}

void loop() {
  if (millis() - lastMs < 2000) return;
  lastMs = millis();

  float h = dht.readHumidity();
  float t = dht.readTemperature();

  if (isnan(h) || isnan(t)) {
    errStreak++;
    Serial.print("ERR:SENSOR_FAIL,streak=");
    Serial.println(errStreak);
    // 3× red blink = sensor problem signal
    for (int i = 0; i < 3; i++) {
      rgb(1,0,0); delay(100); rgb(0,0,0); delay(80);
    }
    return;
  }

  errStreak = 0;
  float hi = heatIndex(t, h);

  // Output parsed by web dashboard: T:xx.x,H:xx.x,HI:xx.x
  Serial.print("T:"); Serial.print(t, 1);
  Serial.print(",H:"); Serial.print(h, 1);
  Serial.print(",HI:"); Serial.println(hi, 1);

  // RGB LED mirrors web dashboard status
  if      (hi < THRESH_CAUTION) rgb(0,1,0);  // GREEN  — Safe
  else if (hi < THRESH_DANGER)  rgb(1,1,0);  // YELLOW — Extreme Caution
  else                           rgb(1,0,0);  // RED    — Danger
}`;
}

// ══════════════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════════════
const S = {
  hasSerial: 'serial' in navigator,
  port: null, reader: null,
  portSelected: false, connected: false, demo: false,
  temp: null, hum: null, hi: null,
  prevT: null, prevH: null, prevHI: null,
  history: { labels:[], hi:[], temp:[], hum:[] },
  chartMode: 'hi', demoTimer: null,
  fwKey: 'esp32', codeVisible: false,
  errStreak: 0, autoFixAttempts: 0, bootWd: null,
};

const PROFILES = {
  esp32:   { name:'ESP32',   baud:115200, pR:25, pG:26, pB:27, pD:4,  dht:22, note:'GPIO25/26/27=RGB  GPIO4=DHT' },
  esp8266: { name:'ESP8266', baud:115200, pR:14, pG:12, pB:13, pD:4,  dht:22, note:'GPIO14/12/13=RGB(D5/D6/D7)  GPIO4=DHT(D2)' },
};

// USB VID → board guess (common ESP dev boards)
const VID_MAP = {
  0x10C4: 'esp32',   // CP2102 — common on ESP32 DevKit
  0x1A86: 'esp8266', // CH340  — common on NodeMCU/Wemos ESP8266
  0x0403: 'esp32',   // FTDI   — various, default esp32
  0x303A: 'esp32',   // Espressif native USB (ESP32-S2/S3/C3)
};

// ══════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════
if (!S.hasSerial) {
  document.getElementById('noSerial').classList.add('show');
  document.getElementById('btnPort').disabled = true;
  document.getElementById('btnCn').disabled = true;
}

// ══════════════════════════════════════════════════════
// PORT SELECTION + AUTO-DETECT
// ══════════════════════════════════════════════════════
async function doSelectPort() {
  if (!S.hasSerial) return;
  try {
    const filters = [
      {usbVendorId:0x10C4,usbProductId:0xEA60},
      {usbVendorId:0x1A86,usbProductId:0x7523},
      {usbVendorId:0x0403,usbProductId:0x6001},
      {usbVendorId:0x0403,usbProductId:0x6010},
      {usbVendorId:0x303A},
    ];
    S.port = await navigator.serial.requestPort({ filters });
    const info = S.port.getInfo();
    const vid = info.usbVendorId;
    S.portSelected = true;

    log(`Port เลือกแล้ว — VID:0x${vid?.toString(16).toUpperCase()??'?'}`, 'ok');
    document.getElementById('portLbl').textContent = 'Port เลือกแล้ว ✓';
    document.getElementById('btnPort').classList.add('found');
    document.getElementById('btnCn').disabled = false;
    document.getElementById('cnTip').textContent = 'เชื่อมต่อ Serial Port';
    document.getElementById('connBar').classList.add('ready');

    const guessed = VID_MAP[vid] || null;
    if (guessed) {
      autoApplyBoard(guessed, `USB VID 0x${vid.toString(16).toUpperCase()}`);
    } else {
      showBanner('info','🔌','เลือก Port สำเร็จ','ตรวจจับประเภทบอร์ดไม่ได้จาก VID — กรุณาเลือกบอร์ดเอง แล้วกด Connect');
      log('ตรวจจับบอร์ดจาก VID ไม่ได้ — กรุณาเลือกเองใน dropdown', 'warn');
    }
  } catch(e) {
    if (e.name !== 'NotFoundError') {
      log('เลือก Port ล้มเหลว: ' + e.message, 'err');
      showBanner('error','❌','เลือก Port ไม่ได้', e.message);
    } else {
      log('ยกเลิกการเลือก Port', 'warn');
    }
  }
}

function autoApplyBoard(key, src) {
  const p = PROFILES[key];
  if (!p) return;
  document.getElementById('selBoard').value = key;
  document.getElementById('selBaud').value = p.baud;
  document.getElementById('pR').value = p.pR;
  document.getElementById('pG').value = p.pG;
  document.getElementById('pB').value = p.pB;
  document.getElementById('pD').value = p.pD;
  // Activate correct fw tab
  const keyMap = {esp32:0,esp8266:1};
  document.querySelectorAll('.fw-tab').forEach((t,i)=>t.classList.toggle('active',i===(keyMap[key]??0)));
  S.fwKey = key;
  document.getElementById('bchipTxt').textContent = `${p.name} detected`;
  document.getElementById('bchip').classList.add('show');
  document.getElementById('adBadge').style.display = 'inline-flex';
  showBanner('detected','✅',`ตรวจพบ ${p.name} อัตโนมัติ`,`ตั้งค่า PIN และ firmware ให้อัตโนมัติ | ${p.note} | แหล่ง: ${src}`);
  log(`Auto-detect: ${p.name} จาก ${src}`, 'ok');
  log(`PIN: R=${p.pR} G=${p.pG} B=${p.pB} DHT=${p.pD} | Baud=${p.baud}`, 'info');
  if (S.codeVisible) updateFwCode();
}

// ══════════════════════════════════════════════════════
// CONNECT / DISCONNECT
// ══════════════════════════════════════════════════════
async function doConnect() {
  if (S.connected) { await doDisconnect(); return; }

  // Guard: port ต้องถูกเลือกก่อน
  if (!S.portSelected || !S.port) {
    showBanner('error','⛔','ยังไม่ได้เลือก Port','กรุณากดปุ่ม "เลือก Port" ก่อน แล้วค่อยกด Connect');
    log('Connect ล้มเหลว — ยังไม่ได้เลือก Serial Port', 'err');
    doShake(document.getElementById('btnPort'));
    return;
  }

  const baud = parseInt(document.getElementById('selBaud').value);
  try {
    if (!S.port.readable) await S.port.open({ baudRate: baud });
    S.connected = true;
    setStatus('online','Connected');
    document.getElementById('btnCn').classList.add('active');
    document.getElementById('btnCn').innerHTML = '■ Disconnect<span class="btooltip">ตัดการเชื่อมต่อ</span>';
    log(`เชื่อมต่อสำเร็จ @ ${baud} baud`, 'ok');
    log('รอข้อมูลจากบอร์ด... (ควรเห็น BOOT: ภายใน 3 วินาที)', 'info');
    startRead();

    // Boot watchdog — ถ้า 5 วินาทียังไม่มีข้อมูล → แจ้งเตือน + Auto-Fix
    S.bootWd = setTimeout(() => {
      if (S.connected && S.temp === null) {
        showBanner('error','⏱','ไม่มีข้อมูลจากบอร์ด',
          'อาจเกิดจาก: ยังไม่ได้ Flash firmware | เซ็นเซอร์ DHT ไม่ได้เสียบ | baud rate ผิด | กด ⚡ Flash เพื่อโหลด firmware');
        log('⚠ Watchdog: ไม่มีข้อมูลใน 5 วินาที', 'warn');
        tryAutoFix('no_data');
      }
    }, 5000);
  } catch(e) {
    log('เปิด Port ไม่ได้: ' + e.message, 'err');
    showBanner('error','❌','เปิด Port ไม่สำเร็จ', e.message + ' — ลองถอดแล้วเสียบใหม่');
  }
}

async function doDisconnect() {
  S.connected = false;
  clearTimeout(S.bootWd);
  if (S.reader) { try { await S.reader.cancel(); } catch(e){} S.reader = null; }
  if (S.port && S.port.readable) { try { await S.port.close(); } catch(e){} }
  setStatus('','Disconnected');
  document.getElementById('btnCn').classList.remove('active');
  document.getElementById('btnCn').innerHTML = '▶ Connect';
  log('ตัดการเชื่อมต่อแล้ว', 'warn');
  lineNotify_offline();
}

// ══════════════════════════════════════════════════════
// SERIAL READ + PARSE
// ══════════════════════════════════════════════════════
async function startRead() {
  const dec = new TextDecoderStream();
  S.port.readable.pipeTo(dec.writable);
  const reader = dec.readable.getReader();
  S.reader = reader;
  let buf = '';
  try {
    while (true) {
      const { value, done } = await reader.read();
      if (done) break;
      buf += value;
      const lines = buf.split('\n');
      buf = lines.pop();
      for (const raw of lines) parseLine(raw.trim());
    }
  } catch(e) {
    if (S.connected) log('Serial หลุด: ' + e.message, 'err');
  }
  if (S.connected) {
    S.connected = false;
    setStatus('','Disconnected');
    document.getElementById('btnCn').classList.remove('active');
    document.getElementById('btnCn').innerHTML = '▶ Connect';
    log('บอร์ดถูกถอดหรือเกิด error — Serial หยุดทำงาน', 'warn');
    tryAutoFix('disconnected');
  }
}

function parseLine(line) {
  if (!line) return;
  clearTimeout(S.bootWd);

  if (line.startsWith('BOOT:')) {
    const name = line.slice(5);
    log(`บอร์ดบูตสำเร็จ: ${name}`, 'ok');
    S.errStreak = 0;
    // Auto-detect from boot string
    if (name.includes('ESP32'))   autoApplyBoard('esp32', 'boot string');
    else if (name.includes('ESP8266')) autoApplyBoard('esp8266', 'boot string');
    return;
  }
  if (line.startsWith('PINS:')) { log('PIN config: ' + line.slice(5), 'info'); return; }

  if (line.startsWith('ERR:')) {
    S.errStreak++;
    const detail = line.slice(4);
    log(`บอร์ด Error [${S.errStreak}]: ${detail}`, 'err');
    showBanner('error','🔴','เซ็นเซอร์อ่านค่าไม่ได้',
      `${detail} | ตรวจสอบ: สายต่อ DHT / ขา DATA / ไฟเลี้ยง 3.3V หรือ 5V`);
    if (S.errStreak >= 3){ tryAutoFix('sensor_err'); lineNotify_sensor(S.errStreak); }
    return;
  }

  const m = line.match(/T:([\d.]+),H:([\d.]+),HI:([\d.]+)/);
  if (m) {
    S.errStreak = 0;
    S.autoFixAttempts = 0;
    hideBanner();
    updateSensor(+m[1], +m[2], +m[3]);
    return;
  }
  // Unknown serial output
  if (line.length > 0 && line.length < 150) log(`Serial: ${line}`, 'info');
}

