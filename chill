function updateFwCode(){
  const is32=S.fwKey.includes('esp32');
  const dht=S.fwKey.includes('d')?11:22;
  const code=genFW(is32?'esp32':'esp8266',dht,
    document.getElementById('pR').value,document.getElementById('pG').value,
    document.getElementById('pB').value,document.getElementById('pD').value);
  let html=code.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  html=html.replace(/(\/\/.*)/g,'<span style="color:#546e7a">$1</span>');
  html=html.replace(/\b(#include|#define|void|float|bool|int|if|else|return|for|while|delay|unsigned|long)\b/g,'<span style="color:#c792ea">$1</span>');
  html=html.replace(/"([^"]*)"/g,'"<span style="color:#c3e88d">$1</span>"');
  document.getElementById('fwCode').innerHTML=html;
}

function toggleCode(){
  S.codeVisible=!S.codeVisible;
  const v=document.getElementById('fwCode');
  if(S.codeVisible){v.classList.add('show');updateFwCode();}else v.classList.remove('show');
}

async function doFlash(){
  if(!S.hasSerial){log('Web Serial ไม่รองรับ — ใช้ Chrome/Edge','err');return;}
  const is32=S.fwKey.includes('esp32'), dht=S.fwKey.includes('d')?11:22;
  const code=genFW(is32?'esp32':'esp8266',dht,
    document.getElementById('pR').value,document.getElementById('pG').value,
    document.getElementById('pB').value,document.getElementById('pD').value);
  const pw=document.getElementById('progWrap'), pb=document.getElementById('pBar'), ps=document.getElementById('pSteps');
  pw.classList.add('show'); ps.innerHTML=''; document.getElementById('doFlashBtn').disabled=true;
  setStatus('flashing','Flashing...');
  const addS=(m,c='cur')=>{const e=document.createElement('div');e.className=`ps ${c}`;e.textContent=m;ps.appendChild(e);ps.scrollTop=ps.scrollHeight;return e;};
  const setP=p=>{pb.style.width=p+'%';};
  try {
    let step=addS('► เลือก Port...'); setP(5);
    if(!S.port) S.port=await navigator.serial.requestPort();
    step.className='ps done';step.textContent='✓ Port เลือกแล้ว'; setP(15); log('Flash: Port ready','ok');
    step=addS('► เปิด port @ 115200...'); 
    if(!S.port.readable) await S.port.open({baudRate:115200});
    step.className='ps done';step.textContent='✓ Port เปิดแล้ว'; setP(25); log('Flash: Port เปิด','ok');
    step=addS('► ส่ง firmware...');
    const enc=new TextEncoder(), w=S.port.writable.getWriter();
    await w.write(enc.encode('\x03\x03')); await sleep(300);
    await w.write(enc.encode('\x01')); await sleep(200);
    const lines=code.split('\n');
    for(let i=0;i<lines.length;i++){
      await w.write(enc.encode(lines[i]+'\n')); setP(25+~~((i/lines.length)*55));
      if(i%15===0) await sleep(15);
    }
    await w.write(enc.encode('\x02')); w.releaseLock();
    step.className='ps done';step.textContent=`✓ ส่ง ${lines.length} บรรทัดแล้ว`; setP(83); log('Flash: Firmware ส่งครบ','ok');
    step=addS('► Reset บอร์ด...');
    if(S.port.setSignals){await S.port.setSignals({dataTerminalReady:false,requestToSend:true});await sleep(200);await S.port.setSignals({dataTerminalReady:true,requestToSend:false});}
    step.className='ps done';step.textContent='✓ Reset สำเร็จ'; setP(93); log('Flash: Reset ส่งแล้ว','ok');
    await sleep(1500); setP(100); addS('✓ Flash เสร็จสมบูรณ์!','done');
    log('⚡ Flash สำเร็จ — เริ่ม Connect อัตโนมัติ','ok');
    S.portSelected=true; S.autoFixAttempts=0;
    document.getElementById('portLbl').textContent='Flash Port ✓';
    document.getElementById('btnPort').classList.add('found');
    document.getElementById('btnCn').disabled=false;
    S.connected=true; setStatus('online','Connected');
    document.getElementById('btnCn').classList.add('active');
    document.getElementById('btnCn').innerHTML='■ Disconnect';
    startRead();
  } catch(e) {
    if(ps.lastChild){ps.lastChild.className='ps err';ps.lastChild.textContent='✗ '+e.message;}
    log('Flash ล้มเหลว: '+e.message,'err');
    showBanner('error','❌','Flash ล้มเหลว',e.message+' — ตรวจสอบสาย USB / บอร์ด / Driver');
    setStatus('','Disconnected');
  }
  document.getElementById('doFlashBtn').disabled=false;
}


