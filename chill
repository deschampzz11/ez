// LINE MESSAGING API SYSTEM
// Push Message to User/Group via Channel Access Token
// ══════════════════════════════════════════════════════
const LINE = {
  token:    '',
  userId:   '',
  proxy:    'https://corsproxy.io/?',
  cooldown: 5,
  lastSent: {},
  triggers: { danger: true, extreme: true },
  enabled:  false,
};

function openLine(){
  document.getElementById('linePanel').classList.add('show');
  loadLine();
}
function closeLine(){ document.getElementById('linePanel').classList.remove('show'); }

function toggleChip(el, key){
  el.classList.toggle('checked');
  LINE.triggers[key] = el.classList.contains('checked');
}

function loadLine(){
  try {
    const saved = JSON.parse(localStorage.getItem('shg_line_msg') || '{}');
    if(saved.token)    { document.getElementById('lineToken').value  = saved.token;    LINE.token    = saved.token; }
    if(saved.userId)   { document.getElementById('lineUserId').value = saved.userId;   LINE.userId   = saved.userId; }
    if(saved.proxy)    { document.getElementById('lineProxy').value  = saved.proxy;    LINE.proxy    = saved.proxy; }
    if(saved.cooldown) { document.getElementById('lineCooldown').value = saved.cooldown; LINE.cooldown = saved.cooldown; }
    if(saved.triggers) {
      Object.assign(LINE.triggers, saved.triggers);
      Object.keys(LINE.triggers).forEach(k=>{
        const el = document.getElementById('chip_'+k);
        if(el) el.classList.toggle('checked', LINE.triggers[k]);
      });
    }
    LINE.enabled = !!(LINE.token && LINE.userId);
    if(LINE.enabled) setLineBadge('ok','✓ Config บันทึกแล้ว');
  } catch(e){}
}

function saveLine(){
  LINE.token    = document.getElementById('lineToken').value.trim();
  LINE.userId   = document.getElementById('lineUserId').value.trim();
  LINE.proxy    = document.getElementById('lineProxy').value.trim() || 'https://corsproxy.io/?';
  LINE.cooldown = parseInt(document.getElementById('lineCooldown').value) || 5;
  LINE.enabled  = !!(LINE.token && LINE.userId);
  try {
    localStorage.setItem('shg_line_msg', JSON.stringify({
      token: LINE.token, userId: LINE.userId, proxy: LINE.proxy,
      cooldown: LINE.cooldown, triggers: LINE.triggers
    }));
  } catch(e){}
  if(!LINE.token)  { setLineBadge('err','❌ กรุณาใส่ Channel Access Token'); return; }
  if(!LINE.userId) { setLineBadge('err','❌ กรุณาใส่ User ID / Group ID'); return; }
  setLineBadge('ok', '✅ บันทึกแล้ว — LINE Messaging API พร้อมใช้งาน');
  log('LINE Messaging API: บันทึก config แล้ว', 'ok');
  log('Target ID: ' + LINE.userId.slice(0,8) + '****', 'info');
}

function setLineBadge(type, msg){
  const el = document.getElementById('lineSendStatus');
  el.className = 'line-status ' + type;
  el.textContent = msg;
  if(type !== 'sending') setTimeout(()=>{ if(el.textContent===msg) el.textContent=''; }, 5000);
