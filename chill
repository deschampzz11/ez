function pickFw(key,btn){
  S.fwKey=key; document.querySelectorAll('.fw-tab').forEach(b=>b.classList.remove('active')); btn.classList.add('active');
  const pins={esp32:{pR:25,pG:26,pB:27,pD:4},esp8266:{pR:14,pG:12,pB:13,pD:4},esp32d:{pR:25,pG:26,pB:27,pD:4},esp8266d:{pR:14,pG:12,pB:13,pD:4}};
  const p=pins[key]; ['pR','pG','pB','pD'].forEach(k=>document.getElementById(k).value=p[k]);
