// AUTO-FIX ENGINE
// ══════════════════════════════════════════════════════
const FIX_RULES = {
  no_data: {
    canFix: true,
    label: 'ไม่มีข้อมูล — ลองเปลี่ยน baud rate',
    fix: async () => {
      const bauds = [115200, 9600, 57600, 38400];
      const cur = parseInt(document.getElementById('selBaud').value);
      const next = bauds.find(b => b !== cur) ?? 115200;
      log(`Auto-Fix: เปลี่ยน baud ${cur} → ${next}`, 'fix');
      document.getElementById('selBaud').value = next;
      if (S.connected) { await doDisconnect(); await sleep(800); await doConnect(); }
    }
  },
  sensor_err: {
    canFix: true,
    label: 'เซ็นเซอร์ error ซ้ำ — ส่ง DTR Reset',
    fix: async () => {
      log('Auto-Fix: ส่ง DTR/RTS reset signal...', 'fix');
      try {
        if (S.port?.setSignals) {
          await S.port.setSignals({ dataTerminalReady:false, requestToSend:true });
          await sleep(220);
          await S.port.setSignals({ dataTerminalReady:true, requestToSend:false });
          log('Auto-Fix: Reset ส่งแล้ว — รอบอร์ดบูตใหม่', 'fix');
          S.errStreak = 0;
        }
      } catch(e) { log('Auto-Fix Reset ล้มเหลว: ' + e.message, 'err'); }
    }
  },
  disconnected: {
    canFix: false, // hw issue → แจ้งเตือนเท่านั้น
    label: 'บอร์ดถูกถอด — ต้องเสียบใหม่',
    fix: async () => {
      log('Auto-Fix: ตรวจพบบอร์ดถูกถอด — reconnect อัตโนมัติไม่ได้ (เสียบสายแล้วกด Connect)', 'warn');
      showBanner('error','🔌','บอร์ดถูกถอดออก','เสียบสาย USB แล้วกด Connect ใหม่');
    }
  }
};

async function tryAutoFix(ruleId) {
  const rule = FIX_RULES[ruleId];
  if (!rule) return;
  if (!rule.canFix) { await rule.fix(); return; }

  S.autoFixAttempts++;
  if (S.autoFixAttempts > 4) {
    log('Auto-Fix: ลองครบ 4 ครั้งแล้ว — อาจเกิดจากวงจรผิด โปรดตรวจสอบด้วยตนเอง', 'err');
    showBanner('error','❌','Auto-Fix ล้มเหลวซ้ำ',
      'ระบบลองแก้ไข 4 ครั้งแล้วไม่สำเร็จ — ตรวจสอบการต่อวงจรด้วยตนเอง หรือกด ⚡ Flash เพื่อโหลด firmware ใหม่');
    showAutoFix(false);
    S.autoFixAttempts = 0;
    return;
  }

  showAutoFix(true, `Auto-Fix #${S.autoFixAttempts}: ${rule.label}`);
  showBanner('fixing','🔧','Auto-Fix กำลังทำงาน...', rule.label + ` (ครั้งที่ ${S.autoFixAttempts}/4)`);
  log(`Auto-Fix เริ่ม [${S.autoFixAttempts}/4]: ${rule.label}`, 'fix');
  await sleep(500);
  await rule.fix();
  await sleep(1000);
  showAutoFix(false);
}

function showAutoFix(on, label='Auto-Fix') {
  const b = document.getElementById('afBadge');
  b.className = 'autofix-badge' + (on?' show':'');
