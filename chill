<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Heat-Guard</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0a0e1a;--bg2:#0f1525;--card:#111827;--card2:#1a2235;
  --border:rgba(99,179,237,0.12);--border2:rgba(99,179,237,0.22);
  --accent:#38bdf8;--accent2:#0ea5e9;
  --green:#22d3a5;--yellow:#fbbf24;--red:#f87171;--orange:#fb923c;
  --text:#e2e8f0;--text2:#94a3b8;--text3:#475569;
  --mono:'DM Mono',monospace;--sans:'Space Grotesk',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(56,189,248,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(56,189,248,0.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;}
body::after{content:'';position:fixed;top:-200px;left:50%;transform:translateX(-50%);width:800px;height:400px;background:radial-gradient(ellipse,rgba(56,189,248,0.06) 0%,transparent 70%);pointer-events:none;z-index:0;}
.wrapper{position:relative;z-index:1;max-width:1300px;margin:0 auto;padding:0 24px 48px;}

header{display:flex;align-items:center;justify-content:space-between;padding:20px 0 22px;border-bottom:1px solid var(--border);margin-bottom:18px;}
.logo{display:flex;align-items:center;gap:12px;}
.logo-icon{width:40px;height:40px;background:linear-gradient(135deg,#0ea5e9,#22d3a5);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;}
.logo-text h1{font-size:18px;font-weight:700;background:linear-gradient(90deg,#38bdf8,#22d3a5);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.logo-text span{font-size:11px;color:var(--text3);font-family:var(--mono);letter-spacing:1.5px;text-transform:uppercase;}
.hdr-right{display:flex;align-items:center;gap:14px;}
.hstatus{display:flex;align-items:center;gap:7px;font-size:12px;color:var(--text2);font-family:var(--mono);}
.dot{width:8px;height:8px;border-radius:50%;background:var(--text3);transition:all .4s;}
.dot.online{background:var(--green);box-shadow:0 0 8px rgba(34,211,165,.8);animation:pdot 2s infinite;}
.dot.warn{background:var(--yellow);box-shadow:0 0 8px rgba(251,191,36,.7);animation:pdot .8s infinite;}
.dot.danger{background:var(--red);box-shadow:0 0 8px rgba(248,113,113,.8);animation:pdot .5s infinite;}
.dot.flashing{background:var(--yellow);box-shadow:0 0 10px rgba(251,191,36,.9);animation:pdot .3s infinite;}
@keyframes pdot{0%,100%{opacity:1}50%{opacity:.3}}
.autofix-badge{display:none;align-items:center;gap:5px;font-family:var(--mono);font-size:10px;padding:2px 9px;border-radius:4px;background:rgba(192,132,252,.12);border:1px solid rgba(192,132,252,.3);color:#c084fc;}
.autofix-badge.show{display:inline-flex;}
.spin{width:8px;height:8px;border:1.5px solid rgba(192,132,252,.3);border-top-color:#c084fc;border-radius:50%;animation:spin .7s linear infinite;display:none;}
.spin.on{display:inline-block;}
@keyframes spin{to{transform:rotate(360deg)}}
.time-disp{font-family:var(--mono);font-size:12px;color:var(--text3);}
.dvr{width:1px;height:26px;background:var(--border);}

/* BANNER */
.banner{border-radius:12px;padding:13px 18px;margin-bottom:14px;display:none;align-items:center;gap:12px;font-size:12px;border:1px solid;animation:fuUp .35s ease;}
.banner.show{display:flex;}
.banner.detected{background:rgba(34,211,165,.07);border-color:rgba(34,211,165,.3);color:var(--green);}
.banner.error{background:rgba(248,113,113,.07);border-color:rgba(248,113,113,.3);color:var(--red);}
.banner.fixing{background:rgba(251,191,36,.07);border-color:rgba(251,191,36,.3);color:var(--yellow);}
.banner.info{background:rgba(56,189,248,.07);border-color:rgba(56,189,248,.25);color:var(--accent);}
.banner-icon{font-size:20px;flex-shrink:0;}
.banner-body{flex:1;}
.banner-title{font-weight:600;font-size:13px;margin-bottom:2px;}
.banner-sub{font-family:var(--mono);font-size:11px;opacity:.85;}
.banner-close{background:none;border:none;color:var(--text3);cursor:pointer;font-size:15px;padding:2px 6px;}
.banner-close:hover{color:var(--text2);}
@keyframes fuUp{from{opacity:0;transform:translateY(-5px)}to{opacity:1;transform:translateY(0)}}

/* CONN BAR */
.conn-bar{background:var(--card);border:1px solid var(--border);border-radius:13px;padding:14px 20px;display:flex;align-items:center;gap:12px;margin-bottom:14px;flex-wrap:wrap;transition:border-color .3s;}
.conn-bar.ready{border-color:rgba(34,211,165,.3);}
.clbl{font-size:11px;color:var(--text3);font-family:var(--mono);white-space:nowrap;}
.csel{background:var(--bg2);border:1px solid var(--border);border-radius:7px;color:var(--text);font-family:var(--mono);font-size:12px;padding:6px 10px;outline:none;transition:border-color .2s;}
.csel:focus{border-color:var(--accent);}
.csel option{background:var(--card);}
.bchip{display:none;align-items:center;gap:7px;background:rgba(34,211,165,.08);border:1px solid rgba(34,211,165,.25);border-radius:8px;padding:5px 12px;font-family:var(--mono);font-size:11px;color:var(--green);}
.bchip.show{display:flex;}

.btn{padding:7px 18px;border-radius:7px;border:1px solid;font-family:var(--mono);font-size:12px;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:6px;white-space:nowrap;position:relative;}
.btn:disabled{opacity:.32;cursor:not-allowed;}
.btn-port{border-color:var(--border2);background:rgba(99,179,237,.07);color:var(--text2);}
.btn-port:hover:not(:disabled){color:var(--accent);border-color:var(--accent);}
.btn-port.found{border-color:var(--green);color:var(--green);background:rgba(34,211,165,.08);}
.btn-cn{border-color:var(--accent2);background:rgba(14,165,233,.12);color:var(--accent);}
.btn-cn:hover:not(:disabled){background:rgba(14,165,233,.22);}
.btn-cn.active{border-color:var(--green);background:rgba(34,211,165,.12);color:var(--green);}
.btn-demo{border-color:var(--border2);background:transparent;color:var(--text2);}
.btn-demo:hover:not(:disabled){color:var(--text);background:var(--card2);}
.btn-flash{border-color:#f59e0b;background:rgba(245,158,11,.1);color:var(--yellow);}
.btn-flash:hover:not(:disabled){background:rgba(245,158,11,.2);}
.btooltip{position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);background:#1a2235;border:1px solid var(--border2);border-radius:6px;padding:5px 10px;font-size:10px;color:var(--text2);white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .2s;z-index:100;}
.btn:hover .btooltip{opacity:1;}

/* NO SERIAL */
.no-serial{background:rgba(251,191,36,.07);border:1px solid rgba(251,191,36,.25);border-radius:10px;padding:10px 16px;font-size:12px;color:var(--yellow);font-family:var(--mono);margin-bottom:14px;display:none;}
.no-serial.show{display:block;}

/* ALERT */
.alert-bar{display:none;align-items:center;gap:12px;background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.3);border-radius:10px;padding:11px 18px;margin-bottom:14px;font-size:13px;}
.alert-bar.show{display:flex;}
.alert-txt{flex:1;color:var(--red);}
.alert-x{background:none;border:none;color:var(--text3);cursor:pointer;font-size:16px;}

/* FLASH PANEL */
.flash-panel{background:var(--card);border:1px solid rgba(245,158,11,.25);border-radius:14px;padding:18px 22px;margin-bottom:14px;display:none;}
.flash-panel.show{display:block;}
.fp-title{display:flex;align-items:center;gap:10px;font-size:14px;font-weight:600;margin-bottom:14px;}
.badge{font-family:var(--mono);font-size:10px;padding:2px 8px;border-radius:4px;}
.by{background:rgba(251,191,36,.15);color:var(--yellow);border:1px solid rgba(251,191,36,.3);}
.bg{background:rgba(34,211,165,.12);color:var(--green);border:1px solid rgba(34,211,165,.25);}
.fw-tabs{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap;}
.fw-tab{font-family:var(--mono);font-size:10px;padding:4px 10px;border-radius:5px;border:1px solid var(--border);background:transparent;color:var(--text3);cursor:pointer;transition:all .2s;}
.fw-tab.active{border-color:var(--accent2);background:rgba(14,165,233,.12);color:var(--accent);}
.fp-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:10px;}
.pin-inp{background:var(--bg2);border:1px solid var(--border);border-radius:7px;color:var(--text);font-family:var(--mono);font-size:12px;padding:6px 10px;outline:none;width:64px;}
.fw-code{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:12px;font-family:var(--mono);font-size:10.5px;line-height:1.7;color:var(--text2);max-height:200px;overflow-y:auto;white-space:pre;display:none;margin-top:10px;}
.fw-code.show{display:block;}
.fw-code::-webkit-scrollbar{width:3px;}
.fw-code::-webkit-scrollbar-thumb{background:var(--border2);}
.prog-wrap{margin-top:12px;display:none;}
.prog-wrap.show{display:block;}
.pbar-bg{background:var(--bg2);border-radius:4px;height:5px;overflow:hidden;margin-bottom:8px;}
.pbar{height:100%;background:linear-gradient(90deg,var(--accent2),var(--green));width:0%;transition:width .3s;}
.psteps{max-height:100px;overflow-y:auto;display:flex;flex-direction:column;gap:3px;}
.ps{font-family:var(--mono);font-size:11px;color:var(--text3);display:flex;gap:8px;}
.ps.done{color:var(--green);}.ps.cur{color:var(--yellow);}.ps.err{color:var(--red);}

/* GRID */
.grid-main{display:grid;grid-template-columns:1fr 1fr 1fr 310px;grid-template-rows:auto auto;gap:16px;}
.card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:20px;position:relative;overflow:hidden;transition:border-color .3s;}
.card:hover{border-color:var(--border2);}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(56,189,248,.28),transparent);}
.clabel{font-size:11px;color:var(--text3);font-family:var(--mono);letter-spacing:1px;text-transform:uppercase;margin-bottom:10px;}
.cval{font-size:48px;font-weight:600;font-family:var(--mono);line-height:1;letter-spacing:-2px;}
.cunit{font-size:18px;font-weight:300;color:var(--text2);margin-left:4px;letter-spacing:0;}
.csub{font-size:12px;color:var(--text3);font-family:var(--mono);margin-top:6px;}
.tc .cval{color:var(--accent);text-shadow:0 0 20px rgba(56,189,248,.3);}
.hc .cval{color:var(--green);text-shadow:0 0 20px rgba(34,211,165,.25);}
.hic .cval{color:var(--yellow);text-shadow:0 0 20px rgba(251,191,36,.25);}
.trend{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-family:var(--mono);padding:2px 8px;border-radius:4px;margin-top:8px;}
.trend.up{background:rgba(248,113,113,.12);color:var(--red);}
.trend.dn{background:rgba(34,211,165,.12);color:var(--green);}
.trend.st{background:rgba(148,163,184,.1);color:var(--text2);}

.led-row{display:flex;align-items:center;gap:8px;margin-top:14px;padding-top:12px;border-top:1px solid var(--border);}
.led{width:13px;height:13px;border-radius:50%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.08);transition:all .5s;flex-shrink:0;}
.led.g{background:#22d3a5;box-shadow:0 0 14px rgba(34,211,165,.9);border-color:#22d3a5;}
.led.y{background:#fbbf24;box-shadow:0 0 14px rgba(251,191,36,.9);border-color:#fbbf24;}
.led.r{background:#f87171;box-shadow:0 0 14px rgba(248,113,113,.9);border-color:#f87171;}
.led-lbl{font-size:10px;font-family:var(--mono);color:var(--text3);}
.led-albl{font-size:10px;font-family:var(--mono);margin-left:auto;padding:2px 8px;border-radius:4px;}
.led-albl.g{background:rgba(34,211,165,.12);color:var(--green);}
.led-albl.y{background:rgba(251,191,36,.12);color:var(--yellow);}
.led-albl.r{background:rgba(248,113,113,.12);color:var(--red);}

.gauge-card{grid-column:span 1;grid-row:span 2;}
.gauge-wrap{display:flex;flex-direction:column;align-items:center;gap:6px;margin:8px 0;}
.gauge-svg{width:220px;height:130px;}
.glvl{font-size:14px;font-weight:600;letter-spacing:.8px;}
.gdesc{font-size:11px;color:var(--text3);font-family:var(--mono);}
.hiscale{width:100%;display:flex;flex-direction:column;gap:6px;margin-top:12px;}
.srow{display:flex;align-items:center;gap:8px;font-size:11px;font-family:var(--mono);}
.sdot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.slbl{color:var(--text2);flex:1;}.srng{color:var(--text3);}

.chart-card{grid-column:span 3;}
.chart-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.chart-ttl{font-size:13px;font-weight:500;}
.ctabs{display:flex;gap:5px;}
.ctab{font-family:var(--mono);font-size:11px;padding:4px 10px;border-radius:5px;border:1px solid var(--border);background:transparent;color:var(--text3);cursor:pointer;transition:all .2s;}
.ctab.active{border-color:var(--accent2);background:rgba(14,165,233,.12);color:var(--accent);}
.chart-wrap{position:relative;height:195px;}

.log-card{grid-row:span 2;}
.log-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.log-ttl{font-size:13px;font-weight:500;}
.log-scroll{height:355px;overflow-y:auto;display:flex;flex-direction:column;gap:5px;}
.log-scroll::-webkit-scrollbar{width:3px;}
.log-scroll::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}
.log-entry{display:flex;gap:8px;font-family:var(--mono);font-size:11px;line-height:1.5;padding:6px 9px;border-radius:7px;background:var(--bg2);border:1px solid var(--border);animation:fuUp .3s ease;}
.lt{color:var(--text3);flex-shrink:0;}
.lm{color:var(--text2);}
.lm.ok{color:var(--green);}.lm.info{color:var(--accent);}.lm.warn{color:var(--yellow);}.lm.err{color:var(--red);}.lm.fix{color:#c084fc;}

@keyframes shake{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-5px)}40%,80%{transform:translateX(5px)}}

/* LINE NOTIFY PANEL */
.line-panel{background:var(--card);border:1px solid rgba(6,199,85,.25);border-radius:14px;padding:18px 22px;margin-bottom:14px;display:none;}
.line-panel.show{display:block;}
.line-title{display:flex;align-items:center;gap:10px;font-size:14px;font-weight:600;margin-bottom:16px;}
.line-logo{width:26px;height:26px;background:#06c755;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.line-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;}
.line-field{display:flex;flex-direction:column;gap:5px;}
.line-field label{font-family:var(--mono);font-size:10px;color:var(--text3);letter-spacing:.8px;text-transform:uppercase;}
.line-inp{background:var(--bg2);border:1px solid var(--border);border-radius:7px;color:var(--text);font-family:var(--mono);font-size:12px;padding:7px 10px;outline:none;transition:border-color .2s;width:100%;}
.line-inp:focus{border-color:#06c755;}
.line-inp.full{grid-column:span 2;}
.line-triggers{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;}
.trigger-chip{display:flex;align-items:center;gap:6px;font-family:var(--mono);font-size:11px;padding:5px 11px;border-radius:6px;border:1px solid var(--border);background:var(--bg2);color:var(--text2);cursor:pointer;transition:all .2s;user-select:none;}
.trigger-chip input{display:none;}
.trigger-chip.checked{border-color:#06c755;background:rgba(6,199,85,.1);color:#06c755;}
.trigger-chip .ticon{font-size:13px;}
.line-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.btn-line-test{border-color:#06c755;background:rgba(6,199,85,.1);color:#06c755;}
.btn-line-test:hover:not(:disabled){background:rgba(6,199,85,.2);}
.btn-line-save{border-color:var(--accent2);background:rgba(14,165,233,.12);color:var(--accent);}
.btn-line-save:hover:not(:disabled){background:rgba(14,165,233,.22);}
.line-status{font-family:var(--mono);font-size:11px;color:var(--text3);}
.line-status.ok{color:#06c755;}.line-status.err{color:var(--red);}.line-status.sending{color:var(--yellow);}
.cooldown-wrap{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:11px;color:var(--text3);}
.cooldown-wrap input{width:70px;}
.notify-log{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:10px;font-family:var(--mono);font-size:11px;max-height:120px;overflow-y:auto;display:flex;flex-direction:column;gap:4px;margin-top:12px;}
.notify-log:empty::before{content:'ยังไม่มีการส่ง notification';color:var(--text3);}
.notify-log::-webkit-scrollbar{width:3px;}
.notify-log::-webkit-scrollbar-thumb{background:var(--border2);}
.nlog-row{display:flex;gap:8px;}
.nlog-t{color:var(--text3);flex-shrink:0;}
.nlog-m{color:var(--text2);}
.nlog-m.ok{color:#06c755;}.nlog-m.err{color:var(--red);}.nlog-m.send{color:var(--yellow);}

@media(max-width:1100px){.grid-main{grid-template-columns:1fr 1fr 310px;}.chart-card{grid-column:span 2;}}
@media(max-width:760px){.grid-main{grid-template-columns:1fr 1fr;}.chart-card,.gauge-card,.log-card{grid-column:span 2;}.log-scroll{height:220px;}}
</style>
</head>
<body>
<div class="wrapper">

<header>
  <div class="logo">
    <div class="logo-icon">🌡️</div>
    <div class="logo-text">
      <h1>Smart Heat-Guard</h1>
      <span>Environmental Monitor v4.0</span>
    </div>
  </div>
  <div class="hdr-right">
    <div class="hstatus">
      <div class="dot" id="hDot"></div>
      <span id="hTxt">Disconnected</span>
      <div class="autofix-badge" id="afBadge">
        <span class="spin" id="afSpin"></span>
        <span id="afLbl">Auto-Fix</span>
      </div>
    </div>
    <div class="dvr"></div>
    <span class="time-disp" id="clockEl">--:--:--</span>
  </div>
</header>

<div class="no-serial" id="noSerial">
  ⚠ เบราว์เซอร์นี้ไม่รองรับ Web Serial API — ใช้ Google Chrome หรือ Microsoft Edge เวอร์ชัน 89+ เพื่อเชื่อมต่อบอร์ดจริง &nbsp;|&nbsp; Demo Mode ยังใช้ได้ปกติ
</div>

<div class="banner" id="mainBanner">
  <span class="banner-icon" id="bannerIcon">🔌</span>
  <div class="banner-body">
    <div class="banner-title" id="bannerTitle"></div>
    <div class="banner-sub" id="bannerSub"></div>
  </div>
  <button class="banner-close" onclick="hideBanner()">✕</button>
</div>

<div class="alert-bar" id="alertBar">
  <span style="font-size:18px">⚠️</span>
  <span class="alert-txt" id="alertTxt"></span>
  <button class="alert-x" onclick="this.parentElement.classList.remove('show')">✕</button>
</div>

<div class="conn-bar" id="connBar">
  <span class="clbl">BOARD</span>
  <select class="csel" id="selBoard">
    <option value="">-- ยังไม่ได้ตรวจจับ --</option>
    <option value="esp32">ESP32</option>
    <option value="esp8266">ESP8266</option>
  </select>

  <span class="clbl">BAUD</span>
  <select class="csel" id="selBaud">
    <option value="9600">9600</option>
    <option value="115200" selected>115200</option>
  </select>

  <div class="bchip" id="bchip">
    <span>✓</span><span id="bchipTxt">ESP32 detected</span>
  </div>
  <div class="dvr"></div>

  <button class="btn btn-port" id="btnPort" onclick="doSelectPort()">
    🔌 เลือก Port
    <span class="btooltip">คลิกเพื่อเลือก USB Serial Port ของบอร์ด</span>
  </button>
  <span style="font-family:var(--mono);font-size:11px;color:var(--text3);" id="portLbl">ยังไม่ได้เลือก port</span>
  <div class="dvr"></div>

  <button class="btn btn-cn" id="btnCn" onclick="doConnect()" disabled>
    ▶ Connect
    <span class="btooltip" id="cnTip">กรุณาเลือก Port ก่อน</span>
  </button>
