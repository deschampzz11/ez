function calcHI(T,H){
  if(T<27) return T;
  return -8.784+1.611*T+2.338*H-0.146*T*H-0.0123*T*T-0.0164*H*H+0.00222*T*T*H+0.000725*T*H*H-0.00000359*T*T*H*H;
}

function updateSensor(t,h,hiIn) {
  S.prevT=S.temp; S.prevH=S.hum; S.prevHI=S.hi;
  S.temp=t; S.hum=h; S.hi=hiIn ?? +(calcHI(t,h).toFixed(1));
  document.getElementById('vT').innerHTML=`${S.temp.toFixed(1)}<span class="cunit">°C</span>`;
  document.getElementById('vH').innerHTML=`${S.hum.toFixed(0)}<span class="cunit">%</span>`;
  document.getElementById('vHI').innerHTML=`${S.hi.toFixed(1)}<span class="cunit">°C</span>`;
  document.getElementById('sT').textContent='DHT sensor reading';
  document.getElementById('sH').textContent='Relative humidity';
  document.getElementById('sHI').textContent=`Feels like ${S.hi.toFixed(1)}°C`;
  setTrend('trT',S.temp,S.prevT); setTrend('trH',S.hum,S.prevH); setTrend('trHI',S.hi,S.prevHI);
  updateGauge(S.hi); updateLEDs(S.hi); pushChart();

  if (S.hi>=41) {
    const m = S.hi>=54
      ? `<strong>⚠ EXTREME DANGER</strong> — Heat Index ${S.hi.toFixed(1)}°C &nbsp;|&nbsp; ไฟแดงบนบอร์ดติดแล้ว`
      : `<strong>⚠ DANGER</strong> — Heat Index ${S.hi.toFixed(1)}°C &nbsp;|&nbsp; ไฟแดงบนบอร์ดติดแล้ว`;
    document.getElementById('alertTxt').innerHTML = m;
    document.getElementById('alertBar').classList.add('show');
    if (!S.prevHI || S.prevHI<41) { log(`⚠ Alert: Heat Index ${S.hi.toFixed(1)}°C — ไฟแดงบนบอร์ดกำลังติด`,'err'); lineNotify_danger(S.hi); }
  } else {
    document.getElementById('alertBar').classList.remove('show');
    if(S.prevHI && S.prevHI>=41){ lineNotify_recover(S.hi); }
  }
}

function setTrend(id,cur,prev) {
  const el=document.getElementById(id);
  if(prev===null){el.className='trend st';el.textContent='— STABLE';return;}
  const d=cur-prev;
  if(Math.abs(d)<0.2){el.className='trend st';el.textContent='— STABLE';}
  else if(d>0){el.className='trend up';el.textContent=`▲ +${Math.abs(d).toFixed(1)}`;}
  else{el.className='trend dn';el.textContent=`▼ -${Math.abs(d).toFixed(1)}`;}
}

function updateLEDs(hi) {
  const g=document.getElementById('ledG'),y=document.getElementById('ledY'),r=document.getElementById('ledR'),lbl=document.getElementById('ledALbl');
  g.className='led';y.className='led';r.className='led';
  if(hi>=41){r.className='led r';lbl.className='led-albl r';lbl.textContent='🔴 Danger';setStatus('danger','Connected — DANGER');}
  else if(hi>=32){y.className='led y';lbl.className='led-albl y';lbl.textContent='🟡 Caution';setStatus('warn','Connected — CAUTION');}
  else{g.className='led g';lbl.className='led-albl g';lbl.textContent='🟢 Safe';setStatus('online','Connected — SAFE');}
}

function updateGauge(hi) {
  const ratio=Math.max(0,Math.min(1,(hi-27)/(54-27)));
  const angle=-180+ratio*180;
  document.getElementById('gNeedle').setAttribute('transform',`rotate(${angle},110,115)`);
  const r=90,cx=110,cy=115,sR=(-180)*Math.PI/180,eR=angle*Math.PI/180;
  const x1=cx+r*Math.cos(sR),y1=cy+r*Math.sin(sR),x2=cx+r*Math.cos(eR),y2=cy+r*Math.sin(eR),la=ratio>.5?1:0;
  let col='#22d3a5',lt='CAUTION',ld='สภาพแวดล้อมปลอดภัย';
  if(hi>=54){col='#f87171';lt='EXTREME DANGER';ld='เสี่ยง heat stroke สูงมาก';}
  else if(hi>=41){col='#fb923c';lt='DANGER';ld='กล้ามเนื้อเป็นตะคริว, เพลียแดด';}
  else if(hi>=32){col='#fbbf24';lt='EXTREME CAUTION';ld='อาจเกิดเพลียแดดได้';}
  document.getElementById('gArc').setAttribute('d',`M ${x1} ${y1} A ${r} ${r} 0 ${la} 1 ${x2} ${y2}`);
  document.getElementById('gArc').setAttribute('stroke',col);
  document.getElementById('glvl').textContent=lt; document.getElementById('glvl').style.color=col;
  document.getElementById('gdesc').textContent=ld;
}

