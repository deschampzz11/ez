function nlog(msg, type='send'){
  const sc = document.getElementById('notifyLog');
  const row = document.createElement('div');
  row.className = 'nlog-row';
  row.innerHTML = `<span class="nlog-t">${new Date().toLocaleTimeString('en-GB')}</span><span class="nlog-m ${type}">${msg}</span>`;
  sc.insertBefore(row, sc.firstChild);
  if(sc.children.length > 30) sc.removeChild(sc.lastChild);
}

// Build LINE Flex Message for heat alert
function buildFlexMessage(level, hi, temp, hum, color, emoji){
  return {
    type: 'flex',
    altText: `${emoji} Smart Heat-Guard — Heat Index ${hi}°C`,
    contents: {
      type: 'bubble',
      size: 'kilo',
      header: {
        type: 'box', layout: 'vertical', backgroundColor: color, paddingAll: '14px',
        contents: [{
          type: 'text', text: `${emoji} ${level}`, color: '#ffffff',
          size: 'lg', weight: 'bold'
        },{
          type: 'text', text: 'Smart Heat-Guard', color: 'rgba(255,255,255,0.75)', size: 'xs'
        }]
      },
      body: {
        type: 'box', layout: 'vertical', paddingAll: '14px', spacing: 'sm',
        contents: [
          { type:'box', layout:'horizontal', contents:[
              {type:'text',text:'🌡 Heat Index',color:'#555',size:'sm',flex:2},
              {type:'text',text:`${hi} °C`,color:'#111',size:'sm',weight:'bold',align:'end',flex:1}
          ]},
          { type:'box', layout:'horizontal', contents:[
              {type:'text',text:'🌡 Temperature',color:'#555',size:'sm',flex:2},
              {type:'text',text:`${temp} °C`,color:'#111',size:'sm',align:'end',flex:1}
          ]},
          { type:'box', layout:'horizontal', contents:[
              {type:'text',text:'💧 Humidity',color:'#555',size:'sm',flex:2},
              {type:'text',text:`${hum} %`,color:'#111',size:'sm',align:'end',flex:1}
          ]},
          { type:'separator', margin:'md' },
          { type:'text', text: new Date().toLocaleString('th-TH'), color:'#aaa', size:'xs', margin:'md' }
        ]
      }
    }
  };
}

async function sendLine(messages, eventKey='manual'){
  const token  = LINE.token  || document.getElementById('lineToken').value.trim();
  const userId = LINE.userId || document.getElementById('lineUserId').value.trim();
  if(!token)  { setLineBadge('err','❌ ไม่มี Channel Access Token'); nlog('❌ ไม่มี Token','err'); return false; }
  if(!userId) { setLineBadge('err','❌ ไม่มี User/Group ID');        nlog('❌ ไม่มี User ID','err'); return false; }

  // Cooldown
  if(eventKey !== 'manual'){
    const last   = LINE.lastSent[eventKey] || 0;
    const coolMs = (LINE.cooldown||5) * 60 * 1000;
    if(Date.now() - last < coolMs){
      const rem = Math.ceil((coolMs-(Date.now()-last))/60000);
      log(`LINE: cooldown ${rem} นาที (${eventKey})`,'warn');
      return false;
    }
  }
  LINE.lastSent[eventKey] = Date.now();

  const gasUrl = LINE.proxy || document.getElementById('lineProxy').value.trim();

  setLineBadge('sending','⏳ กำลังส่ง...');
  nlog(`ส่ง [${eventKey}] → ${userId.slice(0,8)}****`,'send');
  log(`LINE Messaging API: ส่ง [${eventKey}]`,'info');

  // Build plain text message from messages array
  const textMsg = messages.map(m => m.text || (m.altText||'')).filter(Boolean).join('\n');

  try {
    // Send to Google Apps Script (no CORS issue)
    const res = await fetch(gasUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token, userId, message: textMsg })
    });

    const txt = await res.text().catch(()=>'');
    if(res.ok && (txt.includes('ok') || txt.includes('OK') || res.status===200)){
      setLineBadge('ok','✅ ส่งสำเร็จ');
      nlog('✅ Push Message สำเร็จ','ok');
      log(`LINE Messaging API: ส่งสำเร็จ [${eventKey}]`,'ok');
      return true;
    } else {
      setLineBadge('err',`❌ GAS Error: ${txt.slice(0,60)}`);
      nlog(`❌ GAS Error: ${txt.slice(0,80)}`,'err');
      log(`LINE GAS Error: ${txt.slice(0,60)}`,'err');
      return false;
    }
  } catch(e){
    setLineBadge('err','❌ Network error');
    nlog('❌ '+e.message,'err');
    log('LINE Network error: '+e.message,'err');
    return false;
  }
}

async function testLine(){
  const msgs = [{
    type: 'text',
    text: `✅ Smart Heat-Guard — ทดสอบ LINE Messaging API\n⏰ ${new Date().toLocaleString('th-TH')}\n\nระบบแจ้งเตือนพร้อมใช้งานแล้ว 🎉`
  }];
  await sendLine(msgs, 'manual');
}

function lineNotify_danger(hi){
  if(!LINE.enabled) return;
  const t    = (S.temp||0).toFixed(1);
  const h    = (S.hum||0).toFixed(0);
  const hiS  = hi.toFixed(1);

  if(hi >= 54 && LINE.triggers.extreme){
    sendLine([
      buildFlexMessage('EXTREME DANGER', hiS, t, h, '#c0392b', '🆘'),
      { type:'text', text:`🆘 EXTREME DANGER!\nHeat Index: ${hiS}°C\nเสี่ยง Heat Stroke สูงมาก — ต้องการความช่วยเหลือทันที!` }
    ], 'extreme');
  } else if(hi >= 41 && hi < 54 && LINE.triggers.danger){
    sendLine([
      buildFlexMessage('DANGER', hiS, t, h, '#e67e22', '🔴'),
      { type:'text', text:`🔴 DANGER!\nHeat Index: ${hiS}°C\nอุณหภูมิอันตราย — เสี่ยงเพลียแดด` }
    ], 'danger');
  }
}

